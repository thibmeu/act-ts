    "zero-knowledge",
    "proofs",
    "cryptography",
    "schnorr",
    "ietf"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudflare/act-ts.git",
    "directory": "packages/sigma-proofs"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^1.7.2"
  },
  "devDependencies": {
    "vitest": "^3.2.3"
  }
}
