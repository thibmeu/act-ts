{
  "name": "act-ts",
  "version": "0.1.0",
  "description": "Anonymous Credit Tokens (draft-schlesinger-cfrg-act)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.dts.json",
    "build:js": "tsup",
    "build:dts": "tsc -p tsconfig.dts.json",
    "test": "vitest",
    "bench": "vitest bench",
    "examples": "tsx examples/index.ts"
  },
  "keywords": [
    "anonymous",
    "credit",
    "tokens",
    "cryptography",
    "privacy",
    "ietf"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudflare/act-ts.git",
    "directory": "packages/act-ts"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "sigma-proofs": "*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "vitest": "^3.2.3"
  }
}
