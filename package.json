{
  "name": "act-ts-repo",
  "description": "Anonymous Credit Tokens (ACT) implementation in TypeScript",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write . && eslint packages/**/*.ts --ignore-pattern **/dist/** --fix",
    "lint": "prettier --check . && eslint packages/**/*.ts --ignore-pattern **/dist/**",
    "test": "npm run test --workspaces --if-present -- --run",
    "test:coverage": "vitest run --coverage",
    "bench": "npm run bench --workspaces --if-present"
  },
  "license": "Apache-2.0",
  "version": "0.0.0",
  "devDependencies": {
    "@eslint/js": "9.28.0",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "3.2.3",
    "eslint": "9.28.0",
    "eslint-plugin-security": "3.0.1",
    "fast-check": "4.6.0",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.0",
    "vitest": "3.2.3"
  },
  "workspaces": [
    "packages/sigma-proofs",
    "packages/act-ts",
    "packages/privacypass-ts"
  ],
  "packageManager": "npm@11.3.0+sha512.96eb611483f49c55f7fa74df61b588de9e213f80a256728e6798ddc67176c7b07e4a1cfc7de8922422cbce02543714367037536955221fa451b0c4fefaf20c66"
}
